    <!-- Submit -->
    <button type="submit" class="btn bg-cl w-100 fw-bold py-2 rounded-2">
      <i class="fa-solid fa-calendar-check me-2"></i> Book Workspace
    </button>
  </form>
</div>
</div>
</div>
<script src="/css/js/validation.js"></script>
<script>
  // Filter end times based on selected start time
  const startRadios = document.querySelectorAll('input[name="startTime"]');
  const endRadios = document.querySelectorAll('input[name="endTime"]');

  startRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const startValue = radio.value;
      endRadios.forEach(endRadio => {
        if (endRadio.value <= startValue) {
          endRadio.disabled = true;
          endRadio.nextElementSibling.classList.add('disabled');
        } else {
          endRadio.disabled = false;
          endRadio.nextElementSibling.classList.remove('disabled');
        }
      });
    });
  });
</script>
<script src="/css/js/validation.js"></script>