<% layout("/layout/boilerplate") %>
<div class="row justify-content-center">
<div class="col-lg-8 col-md-10 col-sm-12">

<div class="card border-0 shadow-sm p-4 rounded-3">
  <h4 class="card-title mb-4 text-dark fw-bold">Reserve Your Slot</h4>
  
  <form action="/workspaces/<%= workspace._id %>/booking" method="POST" class="needs-validation" novalidate>
    
    <!-- Date -->
    <div class="mb-3">
      <label for="date" class="form-label text-muted fw-semibold small">Choose Date</label>
      <input type="date" class="form-control" id="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" 
      min="<%= new Date().toISOString().split('T')[0] %>" required>
      <div class="invalid-feedback">Please select a valid date.</div>
    </div>
    

    <div class="mb-3">
  <label class="form-label fw-semibold small text-muted">Time Slot</label>
  <div class="btn-group flex-wrap" role="group" aria-label="Time slots">
    <% 
      for (let h = 8; h <= 20; h++) {
          const m=0; // Only generate slots at the start of each hour
          const hour = h.toString().padStart(2, "0");
          const minute = m.toString().padStart(2, "0");
          const time = `${hour}:${minute}- ${(h + 1).toString().padStart(2, "0")}:${minute}`;
    %>
      <input type="radio" class="btn-check" name="time" id="<%= time.replace(':','') %>" value="<%= time %>" required>
      <label class="btn btn-outline-primary m-1" for="<%= time.replace(':','') %>"><%= time %></label>
    <%  } %>
  </div>
</div>
