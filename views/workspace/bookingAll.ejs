<% layout("/layout/boilerplate") %>
<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10 col-sm-12">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h4 class="card-title mb-4 text-dark fw-bold">My Bookings</h4>
            <% if(message){ %>
                <div class="text-center info"><%= message %></div>
            <% } else { %>
                <ul class="list-group">
                    <% bookings.forEach(booking => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Date:</strong> <%= booking.date.toDateString() %><br>
                                <strong>Time:</strong> <%= booking.startTime %> - <%= booking.endTime %>
                                <br>
                                <strong>Workspace:</strong> <%= booking.workspace.category %>
                                &nbsp;
                                <strong>Cafe:</strong> <%= booking.workspace.cafe.name %>
                            </div>
                            <form action="/workspaces/<%= booking.workspace._id %>/booking/<%= booking._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                            </form> 
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </div>    
        <button class="btn bg-cl mt-3" onclick="window.location.href='/cafes'">Back to Home</button>
    </div>
</div>
