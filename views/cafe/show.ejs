<% layout('/layout/boilerplate.ejs') %>

<div class="row m-2">
  <!-- Left column: Cafe info -->
  <div class="col-lg-6">
    <div class="d-flex justify-content-between align-items-center mb-3">
      
      <h1><%= cafe.name %></h1>
      <% if(currUser && cafe.owner && (currUser.username === cafe.owner.username)) { %>
      <div class="d-flex justify-content-end align-items-center gap-2">
                    <button class="btn bg-cl my-3 me-2" onclick="window.location.href='/cafes/<%= cafe._id %>/edit' ">
      Edit Cafe
    </button>
                  <form action="/cafes/<%=cafe.id%>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this cafe?');">
                    <button class="btn bg-cl-red my-3 me-2" type="submit" class="btn btn-sm">
                      Delete Cafe
                    </button>
                  </form>
                  </div>
 <% }%>
    </div>

    <div class="card border-0 my-3">
      <img class="show-image card-img-top" src="<%= cafe.image[0].url %>" alt="">
      <div class="card-body">
        <p class="show-text">In <%= cafe.location %></p>
        <p><%= cafe.description %></p>
        <p>Owned by: <%= cafe.owner.username %></p>
      </div>
    </div>

    <div class="map-container my-3">
      <div id="map" style="height: 220px; width: 100%;"></div>
    </div>
  
      <button class="btn bg-cl my-3" onclick="window.location.href='/cafes' ">
      Back to Home
    </button>
  
  </div>

  <!-- Right column: Workspaces -->
  <div class="col-lg-6">
    <div class="work-info text-muted">
      <% if (workspace.length > 0) { %>
        <div class="d-flex justify-content-between align-items-center">
          <h4>Workspaces available</h4>
          <% if(currUser && cafe.owner && (currUser.username === cafe.owner.username)) { %>
            <button class="btn bg-cl ms-auto mb-2" onclick="window.location.href='/workspaces/new/<%= cafe._id %>' ">
            <i class="fa-solid fa-plus"></i>
          </button>
           <% }%>
        </div>
      <div class="spaces row g-3">
        <% for(let space of workspace) { %>
          <div class="col-12">
            <div class="card h-100 shadow-sm border-0">
              <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center">
                  <h5 class="card-title cl"><%= space.category %></h5>
                  <% if(currUser && cafe.owner && (currUser.username === cafe.owner.username)) { %>
                  <div class="d-flex justify-content-end align-items-center gap-2">
                    <a href="/workspaces/<%=space.id%>/edit" class="btn btn-sm">
                    <i class="fa-solid fa-pen"></i>
                  </a>
                  <form action="/workspaces/<%=space.id%>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this workspace?');">
                    <button type="submit" class="btn btn-sm">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                  </div>
                  <% }%>
                </div>
                <p class="card-text"><%= space.description %></p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                  <span class="text-muted fw-bold">
                    ₹<%= space.price.toLocaleString('en-IN') %> / hour
                  </span>
                  <a href="/workspaces/<%= space._id%>/booking" class="btn ms-2 bg-cl">
                    Book Now
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
        <%}else {%>
          <p class="text-center">No workspaces available.</p>
          <% if(currUser && cafe.owner && (currUser.username === cafe.owner.username)) { %>
          <div class="d-flex justify-content-center">
            <button class="btn bg-cl" onclick="window.location.href='/workspaces/new/<%= cafe._id %>' ">
              Add Workspace
            </button>
          </div>
           <% }%>
        <% } %>
    </div>
  </div>
</div>


<script>
  var cafeCoords = {
    geometry: <%- JSON.stringify(cafe.geometry && cafe.geometry.coordinates.length ? cafe.geometry : {
      type: "Point",
      coordinates: [77.0, 9.96] // fallback
    }) %>,
    location: "<%= cafe.location || 'Default Location' %>",
  };
</script>
<script src="/css/js/map.js"></script>