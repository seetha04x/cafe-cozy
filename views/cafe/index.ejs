<% layout("/layout/boilerplate") %>
<% const msg = typeof message !== 'undefined' ? message : ""; %>
        <div class="row g-3">
            <% if(msg && msg.length>0) { %>
                <div class="text-center italic text-muted fs-5 mt-5">
                    <%=msg%>
                </div>
            <% } %>
            <% for(let data of all) { %>     
            <div class="col-lg-2 col-md-4 col-sm-6 g-3 ">
                <a href="/cafes/<%=data.id%>" class="cafe-link w-100">
                    <div class="card cd h-100 shadow-sm m-3">
                        <img src="<%=data.image[0].url%>" class="card-img-top image" alt="<%=data.name%>">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="card-bottom">
                                <div>
                                    <h5 class="card-title text-dark m-0"><%=data.name%></h5>
                                    <p class="text-muted"><%=data.location%></p>
                                </div>
                                <i class="fa-regular fa-heart"></i>
                                <!-- <i class="fa-solid fa-heart"></i> -->
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% } %>
        </div>
 