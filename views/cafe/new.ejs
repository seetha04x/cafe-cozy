                <label class="form-check-label" for="gridCheck1">Example checkbox</label>
              </div>
            </div>
          </div> -->
          <div class="text-center">
            <button type="submit" class="btn bg-cl px-4">Add</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script src="/css/js/preview.js"></script>